-- =========================================================================
-- MAIN RENDER LOOP (60+ FPS)
-- =========================================================================
_G.TankzRender = RunService.RenderStepped:Connect(function()
    ClearDrawings()
    local mousePos = UIS:GetMouseLocation()
    local myPos = Camera.CFrame.Position 
    
    CreateDrawing("Circle", {
        Thickness = 1.5, NumSides = 60, Color = Color3.fromRGB(255, 255, 255),
        Filled = false, Position = mousePos, Radius = Settings.FOV, Visible = Settings.ShowFOVCircle
    })

    -- 1. ESP LOOP 
    for _, char in pairs(_G.EntityCache) do
        local alive, hum, root, head = IsAlive(char)
        if alive then
            local dist3D = (myPos - root.Position).Magnitude
            if dist3D <= Settings.MaxESPDistance then
                
                local rootPos, rootVis = Camera:WorldToViewportPoint(root.Position)
                local headPos, headVis = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1, 0))
                local legPos, legVis = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))

                if headVis or legVis then
                    local h = legPos.Y - headPos.Y
                    local w = h * 0.55
                    local x = headPos.X - (w / 2)
                    local y = headPos.Y

                    local boxColor = Players:GetPlayerFromCharacter(char) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 165, 0)

                    if Settings.ESP_Box then
                        CreateDrawing("Square", { Size = Vector2.new(w, h), Position = Vector2.new(x, y), Color = boxColor, Thickness = 1.5, Visible = true })
                    end

                    if Settings.ESP_Health then
                        local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        local hpColor = Color3.fromRGB(255 - (hpPct * 255), hpPct * 255, 0)
                        CreateDrawing("Square", {Size = Vector2.new(3, h), Position = Vector2.new(x - 6, y), Color = Color3.fromRGB(0, 0, 0), Filled = true, Visible = true})
                        CreateDrawing("Square", {Size = Vector2.new(1, h * hpPct), Position = Vector2.new(x - 5, y + (h * (1 - hpPct))), Color = hpColor, Filled = true, Visible = true})
                    end

                    if Settings.ESP_Tracer then
                        CreateDrawing("Line", {From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y), To = Vector2.new(legPos.X, legPos.Y), Color = Color3.fromRGB(255, 255, 255), Thickness = 1, Transparency = 0.5, Visible = true})
                    end

                    if Settings.ESP_Distance then
                        local nameTag = Players:GetPlayerFromCharacter(char) and "" or "[BOT] "
                        CreateDrawing("Text", {Text = nameTag .. "[" .. tostring(math.floor(dist3D)) .. "m]", Size = 15, Center = true, Outline = true, Color = Color3.fromRGB(255, 255, 255), Position = Vector2.new(rootPos.X, legPos.Y + 5), Visible = true})
                    end

                    if Settings.ESP_LookDir then
                        local lookTo = head.Position + (head.CFrame.LookVector * 5)
                        local lookScreen, lookV = Camera:WorldToViewportPoint(lookTo)
                        local headScreen, headV = Camera:WorldToViewportPoint(head.Position)
                        if lookV and headV then
                            CreateDrawing("Line", {From = Vector2.new(headScreen.X, headScreen.Y), To = Vector2.new(lookScreen.X, lookScreen.Y), Color = Color3.fromRGB(0, 255, 255), Thickness = 1.5, Visible = true})
                        end
                    end

                    if Settings.ESP_Skeleton then
                        local function DrawLine(p1, p2)
                            local pt1 = char:FindFirstChild(p1)
                            local pt2 = char:FindFirstChild(p2)
                            if pt1 and pt2 then
                                local s1, v1 = Camera:WorldToViewportPoint(pt1.Position)
                                local s2, v2 = Camera:WorldToViewportPoint(pt2.Position)
                                if v1 and v2 then
                                    CreateDrawing("Line", {From = Vector2.new(s1.X, s1.Y), To = Vector2.new(s2.X, s2.Y), Color = Color3.fromRGB(255, 255, 255), Thickness = 1, Visible = true})
                                end
                            end
                        end
                        if char:FindFirstChild("UpperTorso") then
                            DrawLine("Head", "UpperTorso"); DrawLine("UpperTorso", "LowerTorso")
                            DrawLine("UpperTorso", "LeftUpperArm"); DrawLine("LeftUpperArm", "LeftLowerArm")
                            DrawLine("UpperTorso", "RightUpperArm"); DrawLine("RightUpperArm", "RightLowerArm")
                            DrawLine("LowerTorso", "LeftUpperLeg"); DrawLine("LeftUpperLeg", "LeftLowerLeg")
                            DrawLine("LowerTorso", "RightUpperLeg"); DrawLine("RightUpperLeg", "RightLowerLeg")
                        elseif char:FindFirstChild("Torso") then
                            DrawLine("Head", "Torso"); DrawLine("Torso", "Left Arm")
                            DrawLine("Torso", "Right Arm"); DrawLine("Torso", "Left Leg"); DrawLine("Torso", "Right Leg")
                        end
                    end
                end
            end
        end
    end

    -- [SỬA Ở ĐÂY 3]: AIMBOT LOGIC (PRO INPUT FIX) - Tích hợp cả InputTracker + Check chuỗi chữ
    local isAiming = false
    if CurrentAimKey and CurrentAimKey ~= "None" then
        pcall(function()
            local keyStr = tostring(CurrentAimKey)
            if keyStr == "RightClick" or keyStr:find("MouseButton2") then
                isAiming = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or _G.InputTracker[Enum.UserInputType.MouseButton2]
            elseif keyStr == "LeftClick" or keyStr:find("MouseButton1") then
                isAiming = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or _G.InputTracker[Enum.UserInputType.MouseButton1]
            elseif keyStr:find("MouseButton3") then
                isAiming = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton3) or _G.InputTracker[Enum.UserInputType.MouseButton3]
            elseif typeof(CurrentAimKey) == "EnumItem" then
                if CurrentAimKey.EnumType == Enum.UserInputType then
                    isAiming = UIS:IsMouseButtonPressed(CurrentAimKey) or _G.InputTracker[CurrentAimKey]
                elseif CurrentAimKey.EnumType == Enum.KeyCode then
                    isAiming = UIS:IsKeyDown(CurrentAimKey) or _G.InputTracker[CurrentAimKey]
                end
            end
        end)
    end

    if Settings.Aimbot and isAiming then
        local targetHead = GetClosestTarget()
        if targetHead then
            local screenPos = Camera:WorldToViewportPoint(targetHead.Position)
            if mousemoverel then
                mousemoverel((screenPos.X - mousePos.X) / Settings.AimbotSmooth, (screenPos.Y - mousePos.Y) / Settings.AimbotSmooth)
            end
        end
    end

    -- [THÊM LOGIC MỚI]: TRIGGERBOT (KHÔNG AUTO CLICK BẬY BẠ)
    if Settings.TriggerBot and Mouse.Target then
        -- FindFirstAncestorOfClass("Model") sẽ đảm bảo ta lấy chính xác Model của nhân vật,
        -- tránh trường hợp trỏ chuột vào cái Mũ (Accessory) hoặc Súng (Tool) rồi nó bắn loạn xạ.
        local targetModel = Mouse.Target:FindFirstAncestorOfClass("Model")
        
        if targetModel and targetModel ~= LP.Character then
            local alive, _, _, _ = IsAlive(targetModel)
            if alive then
                local distToTarget = (Camera.CFrame.Position - targetModel:GetPivot().Position).Magnitude
                if distToTarget <= Settings.MaxESPDistance then
                    local isRealPlayer = Players:GetPlayerFromCharacter(targetModel) ~= nil
                    if isRealPlayer or Settings.TargetNPCs then
                        if tick() - LastShootTime > 0.15 then
                            if mouse1click then
                                mouse1click()
                                LastShootTime = tick()
                            end
                        end
                    end
                end
            end
        end
    end
end)
