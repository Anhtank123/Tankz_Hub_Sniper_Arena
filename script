-- ENGINE CORE: ENTITY CACHING & STRICT CHECKS
-- =========================================================================
_G.TankzDrawings = _G.TankzDrawings or {}
local function CreateDrawing(type, prop)
    local obj = Drawing.new(type)
    for i, v in pairs(prop) do obj[i] = v end
    table.insert(_G.TankzDrawings, obj)
    return obj
end

local function ClearDrawings()
    for _, d in pairs(_G.TankzDrawings) do if d then d:Remove() end end
    _G.TankzDrawings = {}
end

local function IsAlive(char)
    if not char then return false end
    if not char:IsDescendantOf(workspace) then return false end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    local head = char:FindFirstChild("Head") or char:FindFirstChild("head")
    
    if not hum or not root or not head then return false end
    if hum.Health <= 0.1 or hum:GetState() == Enum.HumanoidStateType.Dead then return false end
    if head.Transparency >= 0.9 then return false end
    
    if (head.Position - root.Position).Magnitude > 8 then return false end
    
    local plr = Players:GetPlayerFromCharacter(char)
    if plr and plr.Character ~= char then return false end
    
    return true, hum, root, head
end

-- HỆ THỐNG QUÉT MỤC TIÊU NGẦM (ENTITY CACHING)
_G.EntityCache = {}
if _G.TankzCacheLoop then task.cancel(_G.TankzCacheLoop) end

_G.TankzCacheLoop = task.spawn(function()
    while task.wait(1) do 
        local newCache = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then table.insert(newCache, p.Character) end
        end
        if Settings.TargetNPCs then
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj ~= LP.Character then
                    local alive = IsAlive(obj)
                    if alive then
                        local isPlayer = false
                        for _, p in pairs(Players:GetPlayers()) do
                            if p.Character == obj then isPlayer = true; break end
                        end
                        if not isPlayer then table.insert(newCache, obj) end
                    end
                end
            end
        end
        _G.EntityCache = newCache
    end
end)

local function GetClosestTarget()
    local target = nil
    local shortestDist = Settings.FOV
    local mousePos = UIS:GetMouseLocation()
    local myPos = Camera.CFrame.Position 

    for _, char in pairs(_G.EntityCache) do
        local alive, hum, root, head = IsAlive(char)
        if alive then
            if (myPos - root.Position).Magnitude <= Settings.MaxESPDistance then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local isVisible = true
                    if not Settings.AimThroughWalls then
                        local partsObscuring = Camera:GetPartsObscuringTarget({head.Position}, {LP.Character, char})
                        if #partsObscuring > 0 then isVisible = false end
                    end

                    if isVisible then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                        if dist < shortestDist then
                            shortestDist = dist
                            target = head
                        end
                    end
                end
            end
        end
    end
    return target
end

